#!hexa strict
// tests/test_lattice.hexa — regression for verify/lattice_check.hexa.
//
// Pass criteria:
//   1. `hexa run verify/lattice_check.hexa` exits 0.
//   2. Output contains `__HEXA_SPACE_LATTICE__ PASS` sentinel.
//   3. CLI proxy `hexa-space verify lattice` likewise emits PASS.
//
// Cost: $0 (Mac local; pure file reads + arithmetic).

fn main() {
    let mut root = env("HEXA_SPACE_ROOT")
    if root.len() == 0 {
        root = exec("pwd").trim()
    }
    println("test_lattice: HEXA_SPACE_ROOT=" + root)

    // ─── 1. direct run of verify/lattice_check.hexa ───
    let direct_p   = root + "/verify/lattice_check.hexa"
    let direct_cmd = "HEXA_SPACE_ROOT=\"" + root + "\" hexa run \"" + direct_p + "\" 2>&1"
    let direct_out = exec(direct_cmd)
    let direct_ok  = direct_out.contains("__HEXA_SPACE_LATTICE__ PASS")
    println("  [direct] verify/lattice_check.hexa  " + str(direct_ok))

    // ─── 2. CLI proxy via `hexa-space verify lattice` ───
    let cli       = root + "/cli/hexa-space.hexa"
    let proxy_cmd = "HEXA_SPACE_ROOT=\"" + root + "\" hexa run \"" + cli + "\" verify lattice 2>&1"
    let proxy_out = exec(proxy_cmd)
    let proxy_ok  = proxy_out.contains("__HEXA_SPACE_LATTICE__ PASS")
    println("  [proxy]  hexa-space verify lattice  " + str(proxy_ok))

    if direct_ok && proxy_ok {
        println("test_lattice: PASS  (lattice_check sentinel + cli proxy both green)")
        return
    }

    println("test_lattice: FAIL")
    if !direct_ok {
        println("--- direct output (last 30 lines) ---")
        println(direct_out.trim())
    }
    if !proxy_ok {
        println("--- proxy output (last 30 lines) ---")
        println(proxy_out.trim())
    }
    exit(1)
}
