    println("hexa-space " + VERSION + " — standalone Space Toolkit CLI (placeholder)")
    println("")
    println("usage: hexa-space <subcmd> [flags...]")
    println("")
    println("group subcommands (5 groups · 27 verbs):")
    println("  group core          (2): cosmic, starship")
    println("  group engineering   (4): aerospace, aerospace_transport, engineering, systems")
    println("  group observation   (3): astrodynamics, astronomy, obs_astronomy")
    println("  group life          (2): astrobiology, medicine")
    println("  group operations    (16, ext): spaceship, satellite, space_center, space_ai_center,")
    println("                      space_datacenter, falcon, dragon, recovery, orbital_depot, hls,")
    println("                      starlink, rideshare, station, mars_base, direct_to_cell, mondaloy")
    println("")
    println("utility subcommands:")
    println("  status              27-verb status table + caveats")
    println("  selftest            canonical-verb presence sweep (11/11 expected)")
    println("  ops [verify-all]    operations-group registry / 16-verb verify sweep")
    println("  verify <verb>       run verify_<verb>.hexa for any registered verb")
    println("  verify lattice      run verify/lattice_check.hexa (n=6 cross-pillar audit)")
    println("  verify cross-doc    run verify/cross_doc_audit.hexa (anchor consistency)")
    println("  verify-all          run every available verify_*.hexa across all 5 groups")
    println("  spacex <subcmd>     SpaceX 2026 program registry (intel/list/active/upcoming")
    println("                      group/show/counts/verify/mk) — see `hexa-space spacex help`")
    println("")
    println("global flags:")
    println("  --version           show version")
    println("  --json              machine-parseable JSON tail")
    println("  --help, -h          this help")
    println("")
    println("env:")
    println("  HEXA_SPACE_ROOT     override repo root (default: inferred from $0)")
    println("")
    println("cost estimate (Mac local): $0 — placeholder dispatcher reads .md specs only.")
}

// ─── main ───

fn main() {
    let _raw = args()
    let mut _sidx = -1
    let mut _i = 0
    while _i < _raw.len() {
        if _raw[_i].ends_with(".hexa") { _sidx = _i; break }
        _i = _i + 1
    }
    let mut _user_start = 2
    if _sidx >= 0 { _user_start = _sidx + 1 }

    let mut a: [str] = ["hexa_space_cli", "hexa_space_router"]
    let mut _ua = _user_start
    while _ua < _raw.len() {
        a = a + [_raw[_ua]]
        _ua = _ua + 1
    }
    let n = len(a)

    if n < 3 {
        cmd_help()
        return
    }

    let sub = a[2]

    if sub == "--version" || sub == "-V" || sub == "version" {
        cmd_version()
        return
    }

    if has_flag(a, "--help") || has_flag(a, "-h") {
        cmd_help()
        return
    }

    if sub == "help"       { cmd_help();         return }
    if sub == "status"     { cmd_status(a);      return }
    if sub == "group"      { cmd_group(a);       return }
    if sub == "selftest"   { cmd_selftest(a);    return }
    if sub == "spacex"     { cmd_spacex(a);      return }
    if sub == "ops"        { cmd_ops(a);         return }
    if sub == "verify"     { cmd_verify(a);      return }
    if sub == "verify-all" { cmd_verify_all(a);  return }

    eprintln("hexa-space: unknown subcommand '" + sub + "'")
    eprintln("run 'hexa-space help' for usage")
    _audit(sub, "", 2)
    exit(2)
}
